<Window x:Class="CmncWanWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CMNC WAN"
        Width="380"
        Height="230"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Left="30"
        Top="30"
        WindowStyle="None"
        ShowInTaskbar="False"
				ShowActivated="False"
        Topmost="False">
	    <Border x:Name="RootBorder"
			    Padding="18"
			    PreviewMouseLeftButtonDown="RootBorder_PreviewMouseLeftButtonDown">
		    <Border.ContextMenu>
			    <ContextMenu>
				    <MenuItem Header="Обновить"
									    Click="RefreshMenuItem_Click"/>

				    <MenuItem x:Name="MoveLockMenuItem"
									    Header="Переместить"
									    Click="MoveLockMenuItem_Click"/>

				    <Separator/>

				    <MenuItem Header="Закрыть"
									    Click="CloseMenuItem_Click"/>
			    </ContextMenu>
		    </Border.ContextMenu>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="ClassroomText"
                       Grid.Row="0"
                       Text="Аудитория: ..."
                       FontSize="18"
                       FontWeight="SemiBold"
											 TextAlignment="Center"
                       TextWrapping="Wrap"/>

            <Border x:Name="StatusBorder"
                    Grid.Row="1"
                    Margin="0,18,0,18"
                    CornerRadius="12"
                    Padding="12"
                    Background="#FFE0E0E0">
                <TextBlock x:Name="StatusText"
                           Text="Загрузка..."
                           FontSize="17"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </Border>

            <UniformGrid Grid.Row="2" Columns="2" Margin="0,0,0,10">
                <Button x:Name="BlockButton"
                        Content="Выключить WAN"
                        Height="38"
                        Margin="0,0,5,0"
                        Click="BlockButton_Click"/>

                <Button x:Name="UnblockButton"
                        Content="Включить WAN"
                        Height="38"
                        Margin="5,0,0,0"
                        Click="UnblockButton_Click"/>
            </UniformGrid>
        </Grid>
    </Border>
</Window>